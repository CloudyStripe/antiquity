{
  "name": "antiquity",
  "version": "0.1.0",
  "description": "Antiquity — a modular, offline-capable ancient-history learning PWA.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/validate-content.mjs",
    "dev": "vite",
    "prebuild": "node scripts/validate-content.mjs && node scripts/gen-icons.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen-icons": "node scripts/gen-icons.mjs",
    "validate-content": "node scripts/validate-content.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.0.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@lucide/svelte": "^1.21.0",
    "canvas-confetti": "^1.9.4",
    "zod": "^4.4.3"
  }
}
